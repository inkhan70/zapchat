# ZapChat Environment Variables
PORT=5000
CLIENT_URL=http://localhost:3000
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# Optional — MongoDB. If unset, the server falls back to in-memory storage.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/zapchat

# ─── Metered Video SDK ────────────────────────────────────────────────────────
# The backend reads METERED_DOMAIN (canonical, per Metered's docs) and
# falls back to METERED_APP_DOMAIN for older deployments. App domain is
# the subdomain of your Metered app — no protocol, no path. Get it from
# the Metered dashboard home page after signup.
METERED_DOMAIN=zapchat-server.metered.live
# METERED_APP_DOMAIN=your-legacy-name.metered.live   # legacy alias, still honoured

# Server-side REST secret. KEEP PRIVATE. Rotate from the Metered dashboard
# "Developers" tab if it ever leaks. Never commit the real value to git.
METERED_SECRET_KEY=your_metered_secret_key_here

# ─── Reverse-proxy plumbing (used by the Vercel frontend) ───────────────────
# BACKEND_URL is the live URL of THIS server (the Back4app instance).
# The Vercel-hosted frontend proxies /api/* and /socket.io/* to this URL
# via rewrites in server/public/vercel.json. Set it on the BACK4APP
# container (or wherever you run this server) so the CORS validator
# auto-allows the proxy's forwarded Origin header when Back4app rotates
# its slug.
#
# Example: BACKEND_URL=https://echochat-abc123.b4a.run
# BACKEND_URL=
