# ZapChat Environment Variables
PORT=5000
NODE_ENV=development

# Frontend / backend URLs
CLIENT_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
SESSION_COOKIE_NAME=zapchat_session

# Security
JWT_SECRET=replace_with_a_long_random_secret
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/zapchat

# Google OAuth (Gmail sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# SMTP for password reset emails (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=ZapChat <no-reply@zapchat.com>

# Optional Metered video config
METERED_APP_DOMAIN=zapchat-server.metered.live
METERED_SECRET_KEY=your_metered_secret_key_here
